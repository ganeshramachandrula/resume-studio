{
  "manifest_version": 2,
  "name": "Resume Studio - Job Description Capture",
  "version": "2.0.0",
  "description": "Capture job descriptions, save to job tracker, and rate companies — all from your favorite job boards.",
  "permissions": [
    "storage",
    "activeTab",
    "https://resume-studio.io/*",
    "https://*.resumestudio.com/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "scripts": ["background/service-worker.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.indeed.com/viewjob*",
        "*://*.indeed.com/jobs*",
        "*://*.indeed.com/rc/*",
        "*://*.linkedin.com/jobs/view/*",
        "*://*.monster.com/job-openings/*",
        "*://*.glassdoor.com/job-listing/*",
        "*://*.dice.com/job-detail/*",
        "*://*.ziprecruiter.com/jobs/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "extension@resume-studio.io",
      "strict_min_version": "109.0"
    }
  }
}
