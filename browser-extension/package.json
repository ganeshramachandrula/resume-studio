{
  "name": "resume-studio-extension",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "BROWSER=chrome ENTRY=popup vite build --watch",
    "build:one": "ENTRY=popup vite build && ENTRY=content vite build && ENTRY=service-worker vite build",
    "build:chrome": "BROWSER=chrome npm run build:one",
    "build:firefox": "BROWSER=firefox npm run build:one",
    "build:edge": "BROWSER=edge npm run build:one",
    "build:all": "npm run build:chrome && npm run build:firefox && npm run build:edge",
    "typecheck": "tsc --noEmit",
    "zip": "bash scripts/zip-builds.sh"
  },
  "dependencies": {
    "preact": "^10.25.4",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.4",
    "@types/webextension-polyfill": "^0.12.1",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}
