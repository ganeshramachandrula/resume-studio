{
  "manifest_version": 3,
  "name": "Resume Studio - Job Description Capture",
  "version": "1.0.0",
  "description": "Capture job descriptions from job boards and generate tailored resumes with Resume Studio.",
  "permissions": ["storage", "activeTab"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.indeed.com/viewjob*",
        "*://*.indeed.com/jobs*",
        "*://*.indeed.com/rc/*",
        "*://*.linkedin.com/jobs/view/*",
        "*://*.monster.com/job-openings/*",
        "*://*.glassdoor.com/job-listing/*",
        "*://*.dice.com/job-detail/*",
        "*://*.ziprecruiter.com/jobs/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://*.resumestudio.com/*"
  ]
}
