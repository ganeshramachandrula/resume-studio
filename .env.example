# ─── Supabase ───────────────────────────────────────────────
# Local Docker: supabase start → copy these from output
# Cloud: create project at supabase.com → Settings > API
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Stripe ─────────────────────────────────────────────────
# dashboard.stripe.com > Developers > API keys (use test mode keys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# stripe listen --forward-to localhost:5000/api/stripe/webhook → copy signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Product Catalog > each product's Price ID
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...
STRIPE_CREDIT_PACK_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_CREDIT_PACK_PRICE_ID=price_...

# ─── AI ─────────────────────────────────────────────────────
# console.anthropic.com > API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:5000

# ─── Admin ──────────────────────────────────────────────────
# Email of the user to bootstrap as super admin (POST /api/admin/bootstrap)
ADMIN_OWNER_EMAIL=admin@example.com

# ─── Google Analytics (optional) ────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─── Job Feed APIs (optional — providers with missing keys are silently skipped) ──
RAPIDAPI_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
FINDWORK_API_KEY=
