# Resume Studio — Production Environment Variables
# Copy to .env.local (or set in Vercel dashboard) and fill in real values.

# ── Supabase (Cloud) ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Stripe (Test Mode initially, then Live) ──────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...
STRIPE_CREDIT_PACK_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_CREDIT_PACK_PRICE_ID=price_...

# ── AI ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://resume-studio.io

# ── Admin ────────────────────────────────────────────────────
ADMIN_OWNER_EMAIL=<your-admin-email>

# ── Extension CORS (set to Chrome extension origin when published) ──
EXTENSION_CORS_ORIGIN=*

# ── Cloudflare Turnstile CAPTCHA ─────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# (Secret key is configured in Supabase dashboard, not here)

# ── Google Analytics (optional) ──────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Job Feed APIs (optional) ─────────────────────────────────
RAPIDAPI_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
FINDWORK_API_KEY=
